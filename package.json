{
	"name": "@anvilkit/plugin-canvas-studio",
	"version": "0.1.7",
	"description": "Canvas Studio integration plugin for Anvilkit Studio — mode-switch, design-block bridge, design:// asset resolver.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./*": {
			"import": {
				"types": "./dist/*.d.ts",
				"default": "./dist/*.js"
			},
			"require": {
				"types": "./dist/*.d.cts",
				"default": "./dist/*.cjs"
			}
		}
	},
	"files": [
		"dist",
		"meta",
		"i18n"
	],
	"license": "MIT",
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@anvilkit/canvas-core": "workspace:*",
		"@anvilkit/canvas-editor": "workspace:*",
		"@puckeditor/core": "^0.21.3",
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"dependencies": {
		"@anvilkit/core": "workspace:*",
		"@anvilkit/design-block": "workspace:*",
		"@anvilkit/plugin-asset-manager": "workspace:*",
		"lucide-react": "^1.21.0"
	},
	"scripts": {
		"build": "rslib build",
		"dev": "rslib build --watch",
		"lint": "pnpm exec biome lint package.json tsconfig.json rslib.config.ts vitest.config.ts src meta",
		"format": "pnpm exec biome check --write package.json tsconfig.json rslib.config.ts vitest.config.ts src meta",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"publint": "publint",
		"size": "size-limit"
	},
	"devDependencies": {
		"@anvilkit/biome-config": "workspace:*",
		"@anvilkit/canvas-core": "workspace:*",
		"@anvilkit/canvas-editor": "workspace:*",
		"@anvilkit/typescript-config": "workspace:*",
		"@anvilkit/vitest-config": "workspace:*",
		"@puckeditor/core": "^0.21.3",
		"@rslib/core": "^0.23.0",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "19.2.3",
		"konva": "^10.3.0",
		"publint": "^0.3.21",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"typescript": "6.0.3",
		"vitest": "^4.1.9"
	}
}
